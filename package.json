{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "install": "lerna bootstrap",
    "build": "lerna run build --scope @eulogise/core && lerna run build --scope @eulogise/client-core --scope @eulogise/mock && lerna run build --scope @eulogise/helpers && lerna run build --scope @eulogise/client-components",
    "build:ui:test-eng-1": "lerna run build:test-eng-1 --scope @eulogise/client",
    "build:ui:test-eng-2": "lerna run build:test-eng-2 --scope @eulogise/client",
    "build:ui:staging": "lerna run build:staging --scope @eulogise/client",
    "build:ui:production-us": "lerna run build:prod-us --scope @eulogise/client",
    "deploy:api:test-eng-1": "lerna run deploy:test-eng-1 --scope @eulogise/api",
    "deploy:api:test-eng-2": "lerna run deploy:test-eng-2 --scope @eulogise/api",
    "deploy:api:staging": "lerna run deploy:staging --scope @eulogise/api",
    "deploy:api:production-us": "lerna run deploy:prod-us --scope @eulogise/api",
    "deploy:generator:test-eng-1": "lerna run deploy:test-eng-1 --scope @eulogise/generator",
    "deploy:generator:test-eng-2": "lerna run deploy:test-eng-2 --scope @eulogise/generator",
    "deploy:generator:staging": "lerna run deploy:staging --scope @eulogise/generator",
    "deploy:generator:production-us": "lerna run deploy:prod-us --scope @eulogise/generator",
    "format:quick": "pretty-quick --staged",
    "start:db:local": "lerna run db:start:local --scope @eulogise/api",
    "start:db:seed:local": "lerna run seed:data:local --scope @eulogise/api",
    "start:api": "lerna run start:local --scope @eulogise/api",
    "start:api:local": "lerna run start:local --scope @eulogise/api",
    "start:ui": "lerna run start --scope @eulogise/client",
    "start:ui:local": "lerna run start:local --scope @eulogise/client",
    "build:ui:e2e": "lerna run build:e2e --scope @eulogise/client",
    "storybook": "lerna run storybook --scope @eulogise/client-components",
    "build:storybook": "lerna run build-storybook --scope @eulogise/client-components",
    "test": "lerna run test --scope @eulogise/helpers --scope @eulogise/client-components",
    "test:generator": "lerna run test --scope @eulogise/generator",
    "test:helpers": "lerna run test --scope @eulogise/helpers",
    "test:clientComponents": "lerna run test --scope @eulogise/client-components",
    "test:e2e:local": "lerna run test:e2e:local --scope @eulogise/client",
    "test:e2e:local:headless": "lerna run test:e2e:local:headless --scope @eulogise/client",
    "ssm:env:all": "yarn workspace @eulogise/client ssm:env:all && yarn workspace @eulogise/api ssm:env:all && yarn workspace @eulogise/generator ssm:env:all",
    "ssm:push:all": "yarn workspace @eulogise/client ssm:push:all && yarn workspace @eulogise/api ssm:push:all && yarn workspace @eulogise/generator ssm:push:all",
    "clean": "lerna run clean",
    "installAndBuild": "yarn install --frozen-lockfile && yarn build",
    "prepare": "husky install",
    "upload-ui-sourcemaps": "bugsnag-source-maps upload-browser --api-key $BUGSNAG_API_KEY --app-version 1.0.0 --base-url $BASE_URL --directory packages/eulogise-client/public --overwrite"
  },
  "devDependencies": {
    "@babel/core": "7.20.7",
    "@babel/parser": "7.20.7",
    "@babel/types": "7.20.7",
    "@types/jest": "^29.2.5",
    "husky": "^8.0.3",
    "lerna": "^6.3.0",
    "pretty-quick": "^3.1.3"
  },
  "resolutions": {
    "@bugsnag/source-maps/form-data": "3.0.4",
    "axios": "1.13.5",
    "**/semver": "7.5.2",
    "**/request/form-data": "2.5.5",
    "**/@cypress/request/form-data": "2.5.5",
    "**/request/qs": "6.14.2",
    "**/@cypress/request/qs": "6.14.2",
    "**/braces": "3.0.3",
    "prebuild-install/tar-fs": "2.1.3",
    "sharp/tar-fs": "3.0.9",
    "gatsby-sharp/tar-fs": "3.0.9",
    "@puppeteer/browsers/tar-fs": "3.0.9",
    "eslint/**/cross-spawn": "7.0.5",
    "execa/**/cross-spawn": "7.0.5",
    "react-dev-utils/**/cross-spawn": "7.0.5",
    "**/qs": "6.14.2",
    "**/body-parser": "1.20.3",
    "yaml-loader/**/yaml": "2.2.2",
    "**/es5-ext": "0.10.63",
    "**/socket.io-adapter/**/ws": "8.17.1",
    "**/jsdom/**/ws": "8.17.1",
    "**/serverless/**/ws": "7.5.10",
    "**/@serverless/platform-client/**/ws": "7.5.10",
    "package-json/**/registry-auth-token": "5.1.1",
    "registry-auth-token/**/@pnpm/npm-conf": "3.0.2",
    "**/fast-xml-parser": "5.3.4"
  }
}
