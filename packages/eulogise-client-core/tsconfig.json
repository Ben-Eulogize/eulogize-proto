{
  "extends": "../../tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "declaration": true,
    "outDir": "./dist",
    "watch": false,
    "declarationMap": true,
    "target": "es2015"
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "dist/**/*",
    "node_modules",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
