{
  "name": "@eulogise/core",
  "private": true,
  "description": "Eulogize Core",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "yarn clean && run-p build:*",
    "build:cjs": "tsc `if [ ! -z $CI ]; then echo '--target es2015'; fi`",
    "build:mjs": "tsc --module esnext --outDir dist/esm",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "csstype": "3.1.2",
    "draft-js": "^0.11.7",
    "filestack-js": "4.3.5"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5",
    "@types/react": "18.0.26",
    "rimraf": "3.0.2"
  }
}
