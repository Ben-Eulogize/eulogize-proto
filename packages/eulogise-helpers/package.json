{
  "name": "@eulogise/helpers",
  "private": true,
  "description": "Eulogize Helpers",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "yarn clean && run-p build:*",
    "build:cjs": "tsc `if [ ! -z $CI ]; then echo '--target es2015'; fi`",
    "build:mjs": "tsc --module esnext --outDir dist/esm",
    "test": "TZ=UTC jest --config test/jest.config.json ---maxWorkers=3",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@eulogise/core": "0.1.0",
    "axios": "1.13.5",
    "copy-to-clipboard": "^3.3.1",
    "draft-js": "^0.11.7",
    "gatsby-link": "5.15.0",
    "immutable": "^4.0.0",
    "jsmediatags": "3.8.1",
    "moment": "2.29.4",
    "mustache": "^4.2.0",
    "parse-full-name": "^1.2.6",
    "ramda": "0.32.0",
    "react": "18.3.0"
  },
  "devDependencies": {
    "@babel/preset-env": "7.20.2",
    "@babel/preset-typescript": "7.18.6",
    "@eulogise/mock": "0.1.0",
    "@faker-js/faker": "8.1.0",
    "@types/draft-js": "0.11.10",
    "@types/jest": "29.2.4",
    "@types/mustache": "^4.2.2",
    "@types/qs": "^6.14.0",
    "@types/ramda": "0.28.20",
    "babel-jest": "29.3.1",
    "jest": "29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "npm-run-all": "4.1.5",
    "rimraf": "3.0.2",
    "ts-jest": "29.0.3"
  }
}
