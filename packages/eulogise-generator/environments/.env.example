# Example environment variables for @eulogise/generator
API_ACCESS_KEY=your_api_access_key
API_SECRET_KEY=your_api_secret_key
API_URL=https://api.example.com
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_REGION=ap-southeast-2
AWS_RESERVED_CONCURRENCY=5
AWS_SDK_LOAD_CONFIG=1
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
CHROME_EXECUTION_PATH=/opt/chromium/chrome
CPDF_BIN=/opt/bin/cpdf
DESIGN_SYSTEM_URL=https://design.example.com
ENABLE_GENERATOR_CLEAN_UP_SCREENSHOTS=true
ENABLE_HTML_GENERATION=true
EULOGIZE_CHROMIUM_LAYER=arn:aws:lambda:ap-southeast-2:123456789012:layer:chromium:1
EULOGIZE_FONTS_LAYER=arn:aws:lambda:ap-southeast-2:123456789012:layer:fonts:1
EULOGIZE_GHOSTSCRIPT_LAYER=arn:aws:lambda:ap-southeast-2:123456789012:layer:ghostscript:1
FFMPEG_LAYER=arn:aws:lambda:ap-southeast-2:123456789012:layer:ffmpeg:1
FFMPEG_PATH=/opt/bin/ffmpeg
FILESTACK_CDN=https://cdn.filestackcontent.com
FONTS_PATH=/opt/fonts
GHOSTSCRIPT_PATH=/opt/bin/gs
IS_LAMBDA_GENERATE_SLIDESHOW=false
SHARP_LAYER=arn:aws:lambda:ap-southeast-2:123456789012:layer:sharp:1
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
TMP_DIR=/tmp
VIDEO_OUTPUT_SIZE=1280x720
XAWS_CLOUDFRONT_MEDIA_DISTRIBUTION_ID=your_distribution_id
XAWS_LAMBDA_ENDPOINT=http://localhost:3002
XAWS_REGION=ap-southeast-2
XAWS_S3_BUCKET=example-media-bucket
XAWS_S3_URL=https://example-media-bucket.s3.ap-southeast-2.amazonaws.com
XAWS_S3_URL_WITHOUT_CDN=https://s3.ap-southeast-2.amazonaws.com/example-media-bucket
