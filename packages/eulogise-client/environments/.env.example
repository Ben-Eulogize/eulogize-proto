# Example environment variables for @eulogise/client
GATSBY_APP_ENDPOINT=https://app.example.com
GATSBY_APP_NAME=Eulogize
GATSBY_AWS_REGION=ap-southeast-2
GATSBY_AWS_S3_BUCKET=example.media.eulogisememorials.com
GATSBY_AWS_S3_URL=https://example.media.eulogisememorials.com
GATSBY_AWS_S3_URL_WITHOUT_CDN=https://s3.ap-southeast-2.amazonaws.com/example.media.eulogisememorials.com
GATSBY_BRAINFISH_WIDGET_KEY=your_brainfish_widget_key
GATSBY_BUGSNAG_API_KEY=your_bugsnag_api_key
GATSBY_BUGSNAG_ENABLED=false
GATSBY_BUGSNAG_RELEASE_STAGE=development
GATSBY_EULOGISE_API_URL=https://api.example.com
GATSBY_FILESTACK_API_KEY=your_filestack_api_key
GATSBY_FILESTACK_CDN=https://cdn.filestackcontent.com
GATSBY_FRESH_CHAT_ID=your_freshchat_id
GATSBY_GOOGLE_MAPS_PLACES_API_KEY=your_google_maps_places_api_key
GATSBY_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
GATSBY_GTM_ID=UA-XXXXXXX-X
GATSBY_PENDO_API_KEY=your_pendo_api_key
GATSBY_STRIPE_API_KEY=your_stripe_api_key
GATSBY_USE_DEVELOPMENT=false
GATSBY_USE_MOCK=false
GATSBY_WEBSOCKET_API_URL=wss://ws.example.com
