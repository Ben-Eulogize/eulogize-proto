{
  "name": "@eulogise/client",
  "version": "1.0.0",
  "private": true,
  "description": "Eulogize Client",
  "scripts": {
    "start": "rm -rf .cache && NODE_OPTIONS=--max-old-space-size=16384 GATSBY_WEBPACK_LOGGING=develop ENV=development gatsby develop -H 0.0.0.0 -p 8080 --verbose",
    "start:local": "rm -rf .cache && NODE_OPTIONS=--max-old-space-size=16384 GATSBY_WEBPACK_LOGGING=develop ENV=local gatsby develop -H 0.0.0.0 -p 8080 --verbose",
    "start:staging": "rm -rf .cache && NODE_OPTIONS=--max-old-space-size=16384 GATSBY_WEBPACK_LOGGING=develop ENV=staging gatsby develop -H 0.0.0.0 -p 8080 --verbose",
    "start:prod-us": "rm -rf .cache && NODE_OPTIONS=--max-old-space-size=16384 NODE_ENV=production GATSBY_WEBPACK_LOGGING=develop ENV=production-us gatsby develop -H 0.0.0.0 -p 8080 --verbose",
    "build:local": "NODE_OPTIONS=--max-old-space-size=8192 ENV=local gatsby build",
    "build:e2e": "NODE_OPTIONS=--max-old-space-size=8192 ENV=e2e gatsby build",
    "build:test-eng-1": "NODE_OPTIONS=--max-old-space-size=8192 ENV=test-eng-1 gatsby build",
    "build:test-eng-2": "NODE_OPTIONS=--max-old-space-size=8192 ENV=test-eng-2 gatsby build",
    "build:proto": "NODE_OPTIONS=--max-old-space-size=8192 ENV=proto gatsby build",
    "build:staging": "NODE_OPTIONS=--max-old-space-size=8192 ENV=staging gatsby build",
    "build:prod-us": "NODE_OPTIONS=--max-old-space-size=8192 NODE_ENV=production ENV=production-us gatsby build",
    "serve": "ENV=development gatsby serve -p 8080",
    "test": "TZ=UTC jest --config test/jest.config.json ---maxWorkers=3",
    "test:e2e:local": "cypress open --config baseUrl=http://localhost:8080",
    "test:e2e:headless": "cypress run --config video=false",
    "test:e2e:local:headless": "cypress run --config video=false",
    "test:e2e:ci": "cypress run --config video=false",
    "clean": "gatsby clean",
    "ssm:env": "node scripts/load-ssm-env.js",
    "ssm:env:all": "node scripts/load-ssm-env-all.js",
    "ssm:push": "node scripts/push-ssm-env.js",
    "ssm:env:development": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env development --path /eulogise/client/development",
    "ssm:env:local": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env local --path /eulogise/client/local",
    "ssm:env:e2e": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env e2e --path /eulogise/client/e2e",
    "ssm:env:proto": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env proto --path /eulogise/client/proto",
    "ssm:env:staging": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env staging --path /eulogise/client/staging",
    "ssm:env:test-eng-1": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test-eng-1 --path /eulogise/client/test-eng-1",
    "ssm:env:test-eng-2": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test-eng-2 --path /eulogise/client/test-eng-2",
    "ssm:env:test.local": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test.local --path /eulogise/client/test.local",
    "ssm:env:production-us": "AWS_REGION=us-east-2 node scripts/load-ssm-env.js --env production-us --path /eulogise/client/production-us",
    "ssm:push:development": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env development --path /eulogise/client/development",
    "ssm:push:local": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env local --path /eulogise/client/local",
    "ssm:push:e2e": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env e2e --path /eulogise/client/e2e",
    "ssm:push:staging": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env staging --path /eulogise/client/staging",
    "ssm:push:test-eng-1": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env test-eng-1 --path /eulogise/client/test-eng-1",
    "ssm:push:test-eng-2": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env test-eng-2 --path /eulogise/client/test-eng-2",
    "ssm:push:test.local": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env test.local --path /eulogise/client/test.local",
    "ssm:push:production-us": "AWS_REGION=us-east-2 node scripts/ssm-push-stage.js --env production-us --path /eulogise/client/production-us",
    "ssm:push:all": "node scripts/ssm-push-all.js"
  },
  "dependencies": {
    "@ant-design/icons": "^4.7.0",
    "@brainfish-ai/web-widget": "^1.19.3",
    "@bugsnag/browser-performance": "^2.13.0",
    "@bugsnag/js": "^8.2.0",
    "@bugsnag/plugin-react": "^8.2.0",
    "@bugsnag/source-maps": "^2.3.3",
    "@eulogise/client-components": "0.1.0",
    "@eulogise/client-core": "0.1.0",
    "@eulogise/core": "^0.1.0",
    "@eulogise/helpers": "0.1.0",
    "@fluentui/react-context-selector": "^0.53.4",
    "@reduxjs/toolkit": "^2.2.7",
    "@stripe/react-stripe-js": "3.7.0",
    "@stripe/stripe-js": "7.3.1",
    "antd": "4.24.16",
    "axios": "1.13.5",
    "axios-mock-adapter": "^1.20.0",
    "bezier-easing": "^2.1.0",
    "copy-to-clipboard": "^3.3.1",
    "draft-js": "^0.11.7",
    "draft-js-export-html": "^1.4.1",
    "filestack-js": "4.3.5",
    "filestack-react": "6.1.0",
    "gatsby": "5.16.1",
    "gatsby-plugin-freshchat": "^1.0.0-rc1",
    "gatsby-plugin-google-tagmanager": "5.11.0",
    "gatsby-plugin-load-script": "^1.1.0",
    "gatsby-plugin-remove-console": "^0.0.2",
    "gatsby-plugin-robots-txt": "^1.8.0",
    "html2canvas": "^1.4.1",
    "image-size": "^1.0.1",
    "immer": "^10.0.3",
    "isomorphic-ws": "5.0.0",
    "jwt-decode": "^4.0.0",
    "moment": "2.29.4",
    "moment-timezone": "0.5.46",
    "path-to-regexp": "6.3.0",
    "qrcode.react": "^3.1.0",
    "qs": "6.14.2",
    "ramda": "0.32.0",
    "react": "18.3.0",
    "react-color": "^2.19.3",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "18.2.0",
    "react-helmet": "^6.1.0",
    "react-hotkeys": "^2.0.0",
    "react-icons": "5.5.0",
    "react-pdf": "9.2.1",
    "react-redux": "^9.1.2",
    "react-slick": "0.31.0",
    "react-syntax-highlighter": "^15.6.1",
    "redux": "^5.0.1",
    "redux-saga": "^1.3.0",
    "slick-carousel": "^1.8.1",
    "styled-components": "5.3.7",
    "usehooks-ts": "^2.9.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.980.0",
    "@babel/helper-explode-assignable-expression": "^7.18.6",
    "@babel/plugin-transform-modules-commonjs": "^7.16.5",
    "@babel/preset-typescript": "^7.16.5",
    "@eulogise/mock": "0.1.0",
    "@faker-js/faker": "8.1.0",
    "@testing-library/cypress": "10.0.1",
    "@testing-library/jest-dom": "6.4.5",
    "@testing-library/react": "15.0.7",
    "@types/expect": "^24.3.0",
    "@types/filestack-react": "^4.0.5",
    "@types/jest": "29.2.4",
    "@types/react-color": "^3.0.12",
    "@types/react-slick": "0.23.13",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-test-renderer": "^17.0.1",
    "@types/sinon": "^10.0.4",
    "@types/styled-components": "^5.1.14",
    "babel-plugin-styled-components": "2.0.7",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-gatsby": "3.7.0",
    "cypress": "13.10.0",
    "dotenv": "^10.0.0",
    "gatsby-plugin-create-client-paths": "4.9.0",
    "gatsby-plugin-image": "3.7.0",
    "gatsby-plugin-less": "^7.13.1",
    "gatsby-plugin-manifest": "5.7.0",
    "gatsby-plugin-react-helmet": "6.7.0",
    "gatsby-plugin-react-svg": "^3.3.0",
    "gatsby-plugin-sharp": "5.7.0",
    "gatsby-plugin-sitemap": "6.7.0",
    "gatsby-plugin-styled-components": "6.7.0",
    "gatsby-source-filesystem": "5.7.0",
    "gatsby-transformer-sharp": "5.7.0",
    "jest": "29.3.1",
    "less": "^4.2.0",
    "prettier": "^2.6.2",
    "sinon": "^11.1.2",
    "start-server-and-test": "^1.14.0",
    "ts-jest": "29.0.3",
    "typescript": "4.6.2"
  }
}
