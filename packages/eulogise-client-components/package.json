{
  "name": "@eulogise/client-components",
  "private": true,
  "description": "Eulogize Client Components",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "yarn clean && run-p build:*",
    "build:cjs": "tsc `if [ ! -z $CI ]; then echo '--target es2015'; fi` && cpx 'src/**/*.svg' dist",
    "build:mjs": "tsc --module esnext --outDir dist/esm && cpx 'src/**/*.svg' dist/esm",
    "test": "TZ=UTC jest --config test/jest.config.json ---maxWorkers=3",
    "clean": "rimraf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "mkdir -p public && storybook build"
  },
  "dependencies": {
    "@eulogise/client-core": "0.1.0",
    "@eulogise/core": "0.1.0",
    "@eulogise/helpers": "0.1.0",
    "@vis.gl/react-google-maps": "^1.1.0",
    "antd": "4.24.16",
    "axios": "1.13.5",
    "bezier-easing": "^2.1.0",
    "draft-js": "^0.11.7",
    "invariant": "^2.2.4",
    "moment": "2.29.4",
    "re-resizable": "6.9.17",
    "react": "18.3.0",
    "react-beautiful-dnd": "^13.1.0",
    "react-dnd": "^16.0.1",
    "react-draggable": "^4.4.6",
    "react-helmet": "^6.1.0",
    "react-hotkeys": "2.0.0",
    "react-icons": "5.5.0",
    "react-measure": "^2.5.2",
    "react-pageflip": "^2.0.3",
    "react-spinners": "0.13.7",
    "styled-components": "5.3.7"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "7.23.0",
    "@chromatic-com/storybook": "^4.1.2",
    "@faker-js/faker": "8.1.0",
    "@storybook/addon-docs": "10.0.7",
    "@storybook/addon-links": "10.0.7",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "10.0.7",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@types/invariant": "^2.2.37",
    "@types/jest": "29.2.4",
    "@types/react": "18.0.26",
    "@types/react-helmet": "6.1.6",
    "babel-jest": "29.3.1",
    "babel-loader": "^8.3.0",
    "cpx": "^1.5.0",
    "env-cmd": "^10.1.0",
    "jest": "29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "npm-run-all": "4.1.5",
    "process": "^0.11.10",
    "react-dom": "^18.2.0",
    "rimraf": "3.0.2",
    "sass": "^1.62.0",
    "sass-loader": "^13.2.2",
    "storybook": "10.0.7",
    "ts-jest": "29.0.3"
  }
}
