# Example environment variables for @eulogise/api
DB_CLEANUP_STRATEGY=soft
DB_PREFIX=dev_
DYNAMODB_CREATE_TABLE_ON_START=false
ENABLE_GENERATOR=true
ENV=development
EULOGISE_API_DOMAIN=api.example.com
EULOGISE_APP_DOMAIN=app.example.com
GENERATOR_API_URL=https://generator.example.com
PASSARE_API_KEY=your_passare_api_key
