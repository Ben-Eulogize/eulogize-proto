{
  "name": "@eulogise/api",
  "version": "0.4.3",
  "main": "dist/index.js",
  "private": true,
  "description": "Eulogise API",
  "scripts": {
    "certificates": "mkdir -p .certificates && openssl req -x509 -sha256 -nodes -newkey rsa:2048 -days 365 -keyout .certificates/key.pem -out .certificates/cert.pem -subj '/CN=api.eulogisememorials.local' &> /dev/null",
    "watch": "env-cmd -f environments/.env.dev.remote node --max-old-space-size=4096 node_modules/.bin/serverless package --stage development --watch",
    "build:dev": "env-cmd -f environments/.env.dev.remote node --max-old-space-size=4096 node_modules/.bin/serverless package --stage development",
    "start": "env-cmd -f environments/.env.dev.remote node --max-old-space-size=4096 node_modules/.bin/serverless offline start --stage development",
    "start:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) node --max-old-space-size=4096 node_modules/.bin/serverless offline start --stage production-us",
    "start:local": "env-cmd -f environments/.env.dev.local node --max-old-space-size=4096 node_modules/.bin/serverless offline start --stage development",
    "lint": "tslint --project ./tsconfig.json",
    "dev": "MODE=development yarn start",
    "test:integration": "mocha --require ts-node/register --file test/globalSetup.ts --ui bdd test/**/*.integration.spec.ts",
    "test:contract": "mocha --require ts-node/register --file test/globalSetup.ts --ui bdd test/**/*.contract.spec.ts",
    "test:unit": "mocha --require ts-node/register --ui bdd test/**/*.spec.ts",
    "test:utils": "mocha --require ts-node/register --ui bdd src/ts/utils/**/*.spec.ts",
    "test": "yarn test:integration && yarn test:contract",
    "ssm:env": "node scripts/load-ssm-env.js",
    "ssm:push": "node scripts/push-ssm-env.js",
    "ssm:env:development": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env development --path /eulogise/api/development",
    "ssm:env:dev.local": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env dev.local --path /eulogise/api/dev.local",
    "ssm:env:dev.remote": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env dev.remote --path /eulogise/api/dev.remote",
    "ssm:env:staging": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env staging --path /eulogise/api/staging",
    "ssm:env:test-eng-1": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test-eng-1 --path /eulogise/api/test-eng-1",
    "ssm:env:test-eng-2": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test-eng-2 --path /eulogise/api/test-eng-2",
    "ssm:env:test.local": "AWS_REGION=ap-southeast-2 node scripts/load-ssm-env.js --env test.local --path /eulogise/api/test.local",
    "ssm:env:production-us": "AWS_REGION=us-east-2 node scripts/load-ssm-env.js --env production-us --path /eulogise/api/production-us",
    "ssm:env:all": "node scripts/load-ssm-env-all.js",
    "ssm:push:development": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --file environments/.env.dev.remote --path /eulogise/api/development",
    "ssm:push:dev.local": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --file environments/.env.dev.local --path /eulogise/api/dev.local",
    "ssm:push:dev.remote": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --file environments/.env.dev.remote --path /eulogise/api/dev.remote",
    "ssm:push:staging": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env staging --path /eulogise/api/staging",
    "ssm:push:test-eng-1": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env test-eng-1 --path /eulogise/api/test-eng-1",
    "ssm:push:test-eng-2": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --env test-eng-2 --path /eulogise/api/test-eng-2",
    "ssm:push:test.local": "AWS_REGION=ap-southeast-2 node scripts/ssm-push-stage.js --file environments/.env.test.local --path /eulogise/api/test.local",
    "ssm:push:production-us": "AWS_REGION=us-east-2 node scripts/ssm-push-stage.js --env production-us --path /eulogise/api/production-us",
    "ssm:push:all": "node scripts/ssm-push-all.js",
    "package:test-eng-1": "env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-1) node_modules/.bin/serverless package --stage test-eng-1",
    "package:test-eng-2": "env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-2) node_modules/.bin/serverless package --stage test-eng-2",
    "package:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) node_modules/.bin/serverless package --stage staging",
    "slsPrune:test-eng-1": "env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-1) node_modules/.bin/serverless prune -n 1",
    "slsPrune:test-eng-2": "env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-2) node_modules/.bin/serverless prune -n 1",
    "slsPrune:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) node_modules/.bin/serverless prune -n 1",
    "slsPrune:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) node_modules/.bin/serverless prune -n 1",
    "deploy:test-eng-1": "yarn slsPrune:test-eng-1 && NODE_OPTIONS=--max-old-space-size=9216 env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-1) node_modules/.bin/serverless deploy --stage test-eng-1 --verbose",
    "deploy:test-eng-2": "yarn slsPrune:test-eng-2 && NODE_OPTIONS=--max-old-space-size=9216 env-cmd -f $(node scripts/resolve-env-file.js --env test-eng-2) node_modules/.bin/serverless deploy --stage test-eng-2 --verbose",
    "deploy:staging": "yarn slsPrune:staging && NODE_OPTIONS=--max-old-space-size=9216 env-cmd -f $(node scripts/resolve-env-file.js --env staging) node_modules/.bin/serverless deploy --stage staging --verbose",
    "deploy:prod-us": "yarn slsPrune:prod-us && NODE_OPTIONS=--max-old-space-size=9216 env-cmd -f $(node scripts/resolve-env-file.js --env production-us) node_modules/.bin/serverless deploy --stage production-us --verbose",
    "db:start:local": "env-cmd -f environments/.env.dev.local ts-node scripts/dynamodbLocalStart.ts",
    "lifecycle:run:local": "env-cmd -f environments/.env.dev.local ts-node scripts/runLifecycleEmails.ts",
    "lifecycle:run:dev": "env-cmd -f environments/.env.dev.remote ts-node scripts/runLifecycleEmails.ts",
    "lifecycle:run:test-eng-1": "env-cmd -f environments/.env.test-eng-1 ts-node scripts/runLifecycleEmails.ts",
    "lifecycle:run:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/runLifecycleEmails.ts",
    "lifecycle:watch:test-eng-1": "env-cmd -f environments/.env.test-eng-1 ts-node scripts/runLifecycleEmails.ts -- --loop --interval=2",
    "lifecycle:watch:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/runLifecycleEmails.ts -- --loop --interval=15",
    "fix:glitch:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/fixGlitches.ts",
    "fix:glitch:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) ts-node scripts/fixGlitches.ts",
    "seed:data:local": "env-cmd -f environments/.env.dev.local ts-node scripts/seed.ts",
    "export:data:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/exportData",
    "export:data:production-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) ts-node scripts/exportData",
    "migrateToV2:data:local": "env-cmd -f environments/.env.dev.local ts-node scripts/migrateDataToV2.ts",
    "migrateToV2:data:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/migrateDataToV2.ts",
    "removeOldAccounts:data:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/removeOldAccounts.ts",
    "removeOldAccounts:data:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) ts-node scripts/removeOldAccounts.ts",
    "reduceBackgroundImageSize:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/reduceBackgroundImageSize.ts",
    "reduceBackgroundImageSize:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) ts-node scripts/reduceBackgroundImageSize.ts",
    "cleanup:s3Bucket:staging": "env-cmd -f $(node scripts/resolve-env-file.js --env staging) ts-node scripts/cleanupS3Bucket.ts",
    "cleanup:s3Bucket:prod-us": "env-cmd -f $(node scripts/resolve-env-file.js --env production-us) ts-node scripts/cleanupS3Bucket.ts"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.922.0",
    "@aws-sdk/client-cloudfront": "^3.922.0",
    "@aws-sdk/client-lambda": "^3.922.0",
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@eulogise/core": "0.1.0",
    "@eulogise/helpers": "0.1.0",
    "@json2csv/plainjs": "^7.0.6",
    "@sendgrid/mail": "8.1.6",
    "axios": "1.13.5",
    "bcryptjs": "^2.4.3",
    "bluebird": "3.7.2",
    "cookie": "^0.3.1",
    "draftjs-to-html": "^0.9.1",
    "dynamodb-local": "^0.0.34",
    "dynamoose": "4.1.5",
    "filestack-js": "4.3.5",
    "form-data": "^4.0.0",
    "heic-decode": "2.1.0",
    "ioredis": "5.6.0",
    "jpeg-js": "^0.4.3",
    "jsonwebtoken": "9.0.3",
    "lambdur": "^0.2.1",
    "moment": "2.29.4",
    "path-to-regexp": "6.3.0",
    "pngjs": "^6.0.0",
    "proportional-scale": "^4.0.0",
    "request": "2.88.2",
    "request-promise-native": "1.0.9",
    "sharp": "^0.33.4",
    "stripe": "20.2.0",
    "uuid": "^3.3.2"
  },
  "devDependencies": {
    "@eulogise/mock": "0.1.0",
    "@faker-js/faker": "8.1.0",
    "@aws-sdk/client-ssm": "^3.980.0",
    "@types/aws-lambda": "8.10.134",
    "@types/bcryptjs": "^2.4.2",
    "@types/bluebird": "3.5.37",
    "@types/cookie": "^0.3.1",
    "@types/draftjs-to-html": "^0.8.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mocha": "10.0.1",
    "@types/node": "20.11.25",
    "@types/path-to-regexp": "1.7.0",
    "@types/request-promise-native": "1.0.18",
    "@types/sharp": "^0.30.0",
    "@types/stripe": "^8.0.417",
    "@types/uuid": "^3.4.4",
    "dotenv": "^10.0.0",
    "env-cmd": "^10.1.0",
    "esbuild": "^0.25.2",
    "esbuild-plugin-tsc": "^0.5.0",
    "expect": "29.4.1",
    "mocha": "^9.0.0",
    "prettier": "^2.3.0",
    "serverless": "4.14.1",
    "serverless-esbuild": "^1.55.0",
    "serverless-offline": "14.4.0",
    "serverless-plugin-lambda-insights": "2.0.0",
    "serverless-plugin-warmup": "8.3.0",
    "serverless-prune-plugin": "2.1.0",
    "sinon": "^14.0.0",
    "ts-loader": "9.4.2",
    "ts-node": "10.9.1",
    "typescript": "4.6.2"
  }
}
