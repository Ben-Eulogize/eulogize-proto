{
  "name": "@eulogise/mock",
  "private": true,
  "description": "Eulogize Mock",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "yarn clean && run-p build:*",
    "build:cjs": "tsc `if [ ! -z $CI ]; then echo '--target es2015'; fi`",
    "build:mjs": "tsc --module esnext --outDir dist/esm",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@eulogise/core": "0.1.0",
    "@eulogise/client-core": "0.1.0",
    "axios": "1.13.5",
    "axios-mock-adapter": "^1.21.2"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5",
    "rimraf": "3.0.2"
  }
}
